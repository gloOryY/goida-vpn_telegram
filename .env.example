# ─── Database ─────────────────────────────────────────────────
POSTGRES_USER=goida
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=goida_vpn

# Database URLs for services
DATABASE_URL_AUTH=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/auth_db
DATABASE_URL_VPN=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/vpn_db
DATABASE_URL_PAYMENT=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/payment_db
DATABASE_URL_NOTIFICATION=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/notification_db

# ─── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRES_IN=7d

# ─── Telegram ─────────────────────────────────────────────────
# Получить у @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ─── Service URLs (для локальной разработки) ──────────────────
AUTH_SERVICE_URL=http://localhost:3001
VPN_SERVICE_URL=http://localhost:3002
PAYMENT_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3004
API_GATEWAY_URL=http://localhost:3000

# ─── Internal service auth ────────────────────────────────────
INTERNAL_SECRET=change_internal_secret_in_production

# ─── Service configuration ────────────────────────────────────
PORT_AUTH=3001
PORT_VPN=3002
PORT_PAYMENT=3003
PORT_NOTIFICATION=3004
PORT_GATEWAY=3000
HOST=0.0.0.0
